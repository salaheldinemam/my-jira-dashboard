# Server (copy to .env in repo root for local dev, or set in environment)
PORT=4000
NODE_ENV=development
SESSION_SECRET=dev-local-session-secret-please-change
# Session cookie lifetime in ms (default 30 days). Cookie extends on each request (rolling).
# SESSION_MAX_AGE_MS=2592000000
# Optional directory for persisted session files (default: .sessions in cwd)
# SESSION_STORE_PATH=.sessions
# Optional: lock CORS to your Vite origin
# CLIENT_ORIGIN=http://localhost:5173

# Atlassian OAuth 3LO (create app at https://developer.atlassian.com/console/myapps/)
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Must match the callback URL registered in your Atlassian app
ATLASSIAN_REDIRECT_URI=http://localhost:4000/api/auth/atlassian/callback
# Optional (defaults shown)
# ATLASSIAN_SCOPES=read:jira-work read:jira-user read:board:jira-software read:sprint:jira-software offline_access

# TLS behind corporate proxy (pick one):
# NODE_EXTRA_CA_CERTS=C:\path\to\your-org-root-ca.pem
# Dev only — disables cert verification for Atlassian/Jira HTTPS (ignored in production):
# ATLASSIAN_INSECURE_TLS=true
